<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network permissions required for Firebase (OTP, Firestore, etc.) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Location permissions for Map / ride booking -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Push notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.QuickSmart">
        <activity
            android:name=".common_activities.SplashActivity"
            android:exported="true"
            android:windowSoftInputMode="stateAlwaysHidden">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".common_activities.LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="stateAlwaysHidden|adjustResize" />

        <activity
            android:name=".common_activities.RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="stateAlwaysHidden|adjustResize" />

        <activity
            android:name=".common_activities.ForgotPasswordActivity"
            android:exported="false"
            android:windowSoftInputMode="stateAlwaysHidden|adjustResize" />

        <activity
            android:name=".common_activities.NotificationsActivity"
            android:exported="false" />



        <!--MAP KEY -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${mapKey}" />

        <!-- ── Main Screens (post-login) ─────────────────────────────────────── -->
        <activity
            android:name=".consumer_activities.ConsumerMainActivity"
            android:exported="false" />

        <activity
            android:name=".consumer_activities.ConsumerMapActivity"
            android:exported="false"
            android:windowSoftInputMode="stateVisible|adjustResize" />

        <activity
            android:name=".consumer_activities.RentVehicleActivity"
            android:exported="false"
            android:windowSoftInputMode="stateVisible|adjustResize" />

        <activity
            android:name=".consumer_activities.ProfileEditActivity"
            android:exported="false"
            android:windowSoftInputMode="stateAlwaysHidden|adjustResize" />

        <activity
            android:name=".consumer_activities.BookingHistoryActivity"
            android:exported="false" />

        <activity
            android:name=".consumer_activities.TransactionHistoryActivity"
            android:exported="false" />

        <activity
            android:name=".consumer_activities.ConsumerPolicyActivity"
            android:exported="false" />

        <activity
            android:name=".consumer_activities.PaymentActivity"
            android:exported="false"
            android:windowSoftInputMode="stateAlwaysHidden" />

        <activity
            android:name=".provider_activities.ProviderMainActivity"
            android:exported="false" />

        <activity
            android:name=".provider_activities.ProviderMapActivity"
            android:exported="false"
            android:windowSoftInputMode="stateVisible|adjustResize" />

        <activity
            android:name=".provider_activities.ProviderProfileEditActivity"
            android:exported="false"
            android:windowSoftInputMode="stateAlwaysHidden|adjustResize" />

        <activity
            android:name=".provider_activities.ProviderBookingHistoryActivity"
            android:exported="false" />

        <activity
            android:name=".provider_activities.ProviderEarningsActivity"
            android:exported="false" />

        <activity
            android:name=".provider_activities.ProviderPolicyActivity"
            android:exported="false" />

        <activity
            android:name=".provider_activities.ProviderRentalBookingsActivity"
            android:exported="false" />

        <activity
            android:name=".provider_activities.ProviderRentalRequestsActivity"
            android:exported="false" />

        <activity
            android:name=".provider_activities.AddVehicleActivity"
            android:exported="false"
            android:windowSoftInputMode="stateAlwaysHidden|adjustResize" />

        <activity
            android:name=".provider_activities.VehicleListActivity"
            android:exported="false" />

        <activity
            android:name=".admin_activities.AdminMainActivity"
            android:exported="false" />

        <activity
            android:name=".admin_activities.AdminProviderRequestsActivity"
            android:exported="false" />

        <activity
            android:name=".admin_activities.AdminProviderListActivity"
            android:exported="false" />

        <activity
            android:name=".admin_activities.AdminVehicleRequestsActivity"
            android:exported="false" />

        <activity
            android:name=".admin_activities.AdminVehicleListActivity"
            android:exported="false" />

        <!-- ── FCM Service ──────────────────────────────────────────────────────── -->
        <service
            android:name=".common_activities.QuickSmartFCMService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>

</manifest>