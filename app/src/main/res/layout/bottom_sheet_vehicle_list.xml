<?xml version="1.0" encoding="utf-8"?>
<!--
    Curved bottom sheet — top corners rounded via shape background.
    Layout:
      1. Drag handle
      2. Sheet title  (full width, own row)
      3. Person selector row  (icon + "Person" label + number-only spinner)
      4. Per-person rate notice
      5. Empty state
      6. RecyclerView
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet_rounded"
    android:paddingTop="@dimen/_8sdp"
    android:paddingBottom="@dimen/_28sdp">

    <!-- Drag handle -->
    <View
        android:layout_width="@dimen/_40sdp"
        android:layout_height="@dimen/_4sdp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="@dimen/_12sdp"
        android:background="@color/lightGray" />

    <!-- Title — full width, own row -->
    <TextView
        android:id="@+id/sheetTitle"
        style="@style/title_style"
        android:text="Available Riders"
        android:textSize="@dimen/_16sdp"
        android:layout_marginHorizontal="@dimen/_15sdp"
        android:layout_marginBottom="@dimen/_10sdp" />

    <!-- Loading indicator (shown while fetching from RTDB) -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="@style/progress_bar_style"
        android:visibility="gone" />

    <!-- Person selector row (icon  •  "Person"  •  number spinner) -->
    <LinearLayout
        android:id="@+id/personSelectorRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginHorizontal="@dimen/_15sdp"
        android:layout_marginBottom="@dimen/_10sdp">

        <!-- Person icon -->
        <ImageView
            android:layout_width="@dimen/_18sdp"
            android:layout_height="@dimen/_18sdp"
            android:src="@drawable/ic_person"
            app:tint="@color/darkPurple"
            android:contentDescription="Person" />

        <!-- "Person" label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Person"
            android:textSize="@dimen/_13sdp"
            android:textColor="@color/darkPurple"
            android:textStyle="bold"
            android:layout_marginStart="@dimen/_6sdp"
            android:layout_marginEnd="@dimen/_10sdp" />

        <!-- Number-only dropdown -->
        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/_8sdp"
            app:cardElevation="@dimen/_2sdp"
            app:cardBackgroundColor="@color/lightGray">

            <Spinner
                android:id="@+id/passengerSpinner"
                android:layout_width="@dimen/_60sdp"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/_8sdp"
                android:paddingVertical="@dimen/_4sdp"
                android:gravity="center"
                android:spinnerMode="dropdown" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Per-person rate notice -->
    <TextView
        android:id="@+id/perPersonRateNotice"
        style="@style/subtitle_style"
        android:layout_marginHorizontal="@dimen/_15sdp"
        android:layout_marginBottom="@dimen/_8sdp"
        android:textColor="@color/darkPurple"
        android:text="Rate shown is per person"
        android:visibility="gone" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/noRidersMessage"
        style="@style/subtitle_style"
        android:text="No riders available nearby. Try again shortly."
        android:textColor="@color/darkGray"
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:layout_marginHorizontal="@dimen/_20sdp"
        android:layout_marginVertical="@dimen/_20sdp"
        android:visibility="gone" />

    <!-- Riders RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/ridersList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="@dimen/_300sdp"
        android:nestedScrollingEnabled="true"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/_8sdp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

</LinearLayout>
