<?xml version="1.0" encoding="utf-8"?>
<!--
    Item card for a single rental vehicle.
    Differences from item_rider.xml:
      • No ETA text view
      • No passenger-count text view
      • Rate label shows "₹X/km" instead of "₹X/person"
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/textbox_card_style"
    android:layout_marginHorizontal="@dimen/_12sdp"
    android:layout_marginBottom="@dimen/_8sdp"
    app:cardBackgroundColor="@color/lightGray"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/_12sdp">

        <!-- Vehicle Icon -->
        <ImageView
            android:id="@+id/rentalVehicleIcon"
            android:layout_width="@dimen/_38sdp"
            android:layout_height="@dimen/_38sdp"
            android:src="@drawable/ic_car"
            app:tint="@color/darkPurple"
            android:contentDescription="Vehicle icon" />

        <!-- Vehicle Info (name + reg number) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/_10sdp">

            <TextView
                android:id="@+id/rentalVehicleName"
                style="@style/subtitle_style"
                android:textStyle="bold"
                android:layout_marginTop="0dp" />

            <TextView
                android:id="@+id/rentalVehicleNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/_11sdp"
                android:textColor="@color/darkGray" />

        </LinearLayout>

        <!-- Per-km rate (right side) -->
        <TextView
            android:id="@+id/rentalVehicleRate"
            style="@style/subtitle_style"
            android:textStyle="bold"
            android:textColor="@color/darkPurple"
            android:layout_marginTop="0dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
