<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- App Bar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            style="@style/app_bar_style"
            app:title="Add Vehicle"
            app:navigationIcon="@drawable/ic_back" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/_15sdp">

            <!-- Vehicle Type label -->
            <TextView
                style="@style/subtitle_style"
                android:text="Vehicle Type"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/_4sdp" />

            <!-- Vehicle Type spinner -->
            <androidx.cardview.widget.CardView
                style="@style/textbox_card_style"
                app:cardBackgroundColor="@color/lightGray"
                android:layout_marginBottom="@dimen/_15sdp">

                <Spinner
                    android:id="@+id/vehicle_type_spinner"
                    style="@style/spinner_style" />

            </androidx.cardview.widget.CardView>

            <!-- Vehicle Number label -->
            <TextView
                style="@style/subtitle_style"
                android:text="Vehicle Number"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/_4sdp" />

            <androidx.cardview.widget.CardView
                style="@style/textbox_card_style"
                app:cardBackgroundColor="@color/lightGray"
                android:layout_marginBottom="@dimen/_15sdp">

                <EditText
                    android:id="@+id/vehicle_number_input"
                    style="@style/textbox_style"
                    android:background="@null"
                    android:hint="e.g. GJ 01 AB 1234"
                    android:inputType="textCapCharacters"
                    android:imeOptions="actionNext" />

            </androidx.cardview.widget.CardView>

            <!-- Seat Count label -->
            <TextView
                android:id="@+id/seat_count_label"
                style="@style/subtitle_style"
                android:text="Seat Count (excluding driver)"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/_4sdp" />

            <!-- Seat Count spinner -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_seat_count"
                style="@style/textbox_card_style"
                app:cardBackgroundColor="@color/lightGray"
                android:layout_marginBottom="@dimen/_15sdp">

                <Spinner
                    android:id="@+id/seat_count_spinner"
                    style="@style/spinner_style" />

            </androidx.cardview.widget.CardView>

            <!-- Vehicle Purpose label -->
            <TextView
                style="@style/subtitle_style"
                android:text="Vehicle Purpose"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/_4sdp" />

            <!-- Vehicle Purpose spinner -->
            <androidx.cardview.widget.CardView
                style="@style/textbox_card_style"
                app:cardBackgroundColor="@color/lightGray"
                android:layout_marginBottom="@dimen/_20sdp">

                <Spinner
                    android:id="@+id/vehicle_purpose_spinner"
                    style="@style/spinner_style" />

            </androidx.cardview.widget.CardView>

            <!-- Pricing Section -->
            <LinearLayout
                android:id="@+id/layout_pricing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    style="@style/subtitle_style"
                    android:text="Price per KM (₹)"
                    android:textStyle="bold"
                    android:layout_marginBottom="@dimen/_4sdp" />

                <androidx.cardview.widget.CardView
                    style="@style/textbox_card_style"
                    app:cardBackgroundColor="@color/lightGray"
                    android:layout_marginBottom="@dimen/_20sdp">

                    <EditText
                        android:id="@+id/price_per_km_input"
                        style="@style/textbox_style"
                        android:background="@null"
                        android:hint="e.g. 15.50"
                        android:inputType="numberDecimal"
                        android:imeOptions="actionDone" />

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- RC Document label -->
            <TextView
                style="@style/subtitle_style"
                android:text="RC Document (PDF only)"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/_4sdp" />

            <!-- RC upload card (tap to pick PDF) -->
            <androidx.cardview.widget.CardView
                style="@style/textbox_card_style"
                app:cardBackgroundColor="@color/lightGray"
                android:layout_marginBottom="@dimen/_20sdp"
                android:clickable="true"
                android:focusable="true"
                android:id="@+id/card_upload_rc">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/_12sdp">

                    <ImageView
                        android:layout_width="@dimen/_22sdp"
                        android:layout_height="@dimen/_22sdp"
                        android:src="@drawable/ic_upload"
                        app:tint="@color/darkPurple"
                        android:contentDescription="Upload RC"
                        android:layout_marginEnd="@dimen/_10sdp" />

                    <TextView
                        android:id="@+id/rc_file_name"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Tap to upload RC (PDF)"
                        android:textSize="@dimen/_13sdp"
                        android:textColor="@color/transparentPurple" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Submit button + progress -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <Button
                    android:id="@+id/btn_submit_vehicle"
                    style="@style/btn_style"
                    android:layout_marginTop="0dp"
                    android:text="Submit Vehicle" />

                <ProgressBar
                    android:id="@+id/progress_bar"
                    style="@style/progress_bar_style"
                    android:layout_gravity="center"
                    android:visibility="gone" />

            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
