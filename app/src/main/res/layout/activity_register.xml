<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="true"
    tools:context=".common_activities.RegisterActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="@dimen/_15sdp"
        android:paddingBottom="@dimen/_28sdp">

        <!-- Hero Image -->
        <ImageView
            android:src="@drawable/car_sharing_img"
            android:layout_width="match_parent"
            android:scaleType="fitCenter"
            android:layout_height="@dimen/_180sdp"
            android:contentDescription="@string/app_name" />

        <!-- Title -->
        <TextView
            style="@style/title_style"
            android:text="Create Account" />

        <!-- Subtitle -->
        <TextView
            style="@style/subtitle_style"
            android:text="Fill in the details below to register" />

        <!-- Role Selector Card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            style="@style/textbox_card_style"
            android:layout_marginTop="@dimen/_15sdp"
            app:cardBackgroundColor="@color/lightGray">

            <Spinner
                android:id="@+id/spinner_role"
                style="@style/spinner_style"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </androidx.cardview.widget.CardView>

        <!-- First Name / Last Name Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_10sdp"
            android:orientation="horizontal"
            android:weightSum="2">

            <!-- First Name Card -->
            <androidx.cardview.widget.CardView
                style="@style/textbox_card_style"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/_5sdp">

                <EditText
                    android:id="@+id/first_name"
                    style="@style/textbox_style"
                    android:hint="First Name"
                    android:inputType="textPersonName" />

            </androidx.cardview.widget.CardView>

            <!-- Last Name Card -->
            <androidx.cardview.widget.CardView
                style="@style/textbox_card_style"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/_5sdp">

                <EditText
                    android:id="@+id/last_name"
                    style="@style/textbox_style"
                    android:hint="Last Name"
                    android:inputType="textPersonName" />

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Email Input Card -->
        <androidx.cardview.widget.CardView
            style="@style/textbox_card_style"
            android:layout_marginTop="@dimen/_10sdp">

            <EditText
                android:id="@+id/email"
                style="@style/textbox_style"
                android:hint="Enter Email"
                android:inputType="textEmailAddress" />

        </androidx.cardview.widget.CardView>

        <!-- Mobile No (all users) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_mobile"
            style="@style/textbox_card_style"
            android:layout_marginTop="@dimen/_10sdp">

            <EditText
                android:id="@+id/mobile"
                style="@style/textbox_style"
                android:hint="Enter Mobile No"
                android:inputType="phone"
                android:maxLength="10" />

        </androidx.cardview.widget.CardView>

        <!-- ── Provider-only fields ── -->

        <!-- ── Common fields (Password / Confirm Password) ── -->

        <!-- Password Input Card -->
        <androidx.cardview.widget.CardView
            style="@style/textbox_card_style"
            android:layout_marginTop="@dimen/_10sdp">

            <EditText
                android:id="@+id/password"
                style="@style/textbox_style"
                android:hint="Enter Password"
                android:inputType="textPassword" />

        </androidx.cardview.widget.CardView>

        <!-- Confirm Password Input Card -->
        <androidx.cardview.widget.CardView
            style="@style/textbox_card_style"
            android:layout_marginTop="@dimen/_10sdp">

            <EditText
                android:id="@+id/confirm_password"
                style="@style/textbox_style"
                android:hint="Confirm Password"
                android:inputType="textPassword" />

        </androidx.cardview.widget.CardView>

        <!-- ── Aadhaar PDF Upload (Provider only) ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_aadhaar"
            style="@style/textbox_card_style"
            android:layout_marginTop="@dimen/_10sdp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/lightGray"
                android:padding="@dimen/_10sdp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/aadhaar_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Upload Aadhaar Card (PDF)"
                    android:textColor="@color/transparentPurple"
                    android:textSize="@dimen/_15sdp"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <ImageButton
                    android:id="@+id/btn_upload_aadhaar"
                    android:layout_width="@dimen/_36sdp"
                    android:layout_height="@dimen/_36sdp"
                    android:src="@drawable/ic_upload"
                    android:background="@android:color/transparent"
                    android:contentDescription="Upload Aadhaar PDF"
                    android:padding="@dimen/_4sdp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ── Licence PDF Upload (Provider only) ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_licence"
            style="@style/textbox_card_style"
            android:layout_marginTop="@dimen/_10sdp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/lightGray"
                android:padding="@dimen/_10sdp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/licence_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Upload Licence (PDF)"
                    android:textColor="@color/transparentPurple"
                    android:textSize="@dimen/_15sdp"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <ImageButton
                    android:id="@+id/btn_upload_licence"
                    android:layout_width="@dimen/_36sdp"
                    android:layout_height="@dimen/_36sdp"
                    android:src="@drawable/ic_upload"
                    android:background="@android:color/transparent"
                    android:contentDescription="Upload Licence PDF"
                    android:padding="@dimen/_4sdp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Register Button + Progress Bar (toggle visibility in code) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_15sdp">

            <Button
                android:id="@+id/btn_register"
                style="@style/btn_style"
                android:layout_marginTop="0dp"
                android:text="Register" />

            <ProgressBar
                android:id="@+id/progress_bar"
                style="@style/progress_bar_style"
                android:layout_gravity="center"
                android:visibility="gone" />

        </FrameLayout>

        <!-- Already have account link -->
        <TextView
            android:id="@+id/login"
            style="@style/text_style"
            android:text="Already have an account? Login" />

    </LinearLayout>

</ScrollView>
