<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="true"
    tools:context=".common_activities.LoginActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="@dimen/_15sdp"
        android:paddingVertical="@dimen/_34sdp">

        <!-- Hero Image -->
        <ImageView
            android:src="@drawable/car_sharing_img"
            android:layout_width="match_parent"
            android:scaleType="fitCenter"
            android:layout_height="@dimen/_200sdp"
            android:contentDescription="@string/app_name" />

        <!-- Title -->
        <TextView
            style="@style/title_style"
            android:text="Welcome To QuickSmart" />

        <!-- Subtitle -->
        <TextView
            style="@style/subtitle_style"
            android:text="Login to your account" />

        <!-- Email Input Card -->
        <androidx.cardview.widget.CardView
            style="@style/textbox_card_style"
            android:layout_marginTop="@dimen/_15sdp">

            <EditText
                android:id="@+id/email"
                style="@style/textbox_style"
                android:hint="Enter Email"
                android:inputType="textEmailAddress" />

        </androidx.cardview.widget.CardView>

        <!-- Password Input Card -->
        <androidx.cardview.widget.CardView
            style="@style/textbox_card_style"
            android:layout_marginTop="@dimen/_10sdp">

            <EditText
                android:id="@+id/password"
                style="@style/textbox_style"
                android:hint="Enter Password"
                android:inputType="textPassword" />

        </androidx.cardview.widget.CardView>

        <!-- Forgot Password Link -->
        <TextView
            android:id="@+id/forgot_password"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/_13sdp"
            android:text="Forgot Password?"
            android:textColor="@color/lightPurple"
            android:layout_gravity="end"
            android:layout_marginTop="@dimen/_8sdp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />

        <!-- Login Button + Progress Bar (toggle visibility in code) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_15sdp">

            <Button
                android:id="@+id/btn_login"
                style="@style/btn_style"
                android:layout_marginTop="0dp"
                android:text="Login" />

            <ProgressBar
                android:id="@+id/progress_bar"
                style="@style/progress_bar_style"
                android:layout_gravity="center"
                android:visibility="gone" />

        </FrameLayout>

        <!-- Register Link -->
        <TextView
            android:id="@+id/register"
            style="@style/text_style"
            android:text="Don't have an account? Register" />

    </LinearLayout>

</ScrollView>