<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/textbox_card_style"
    android:layout_marginHorizontal="@dimen/_15sdp"
    android:layout_marginBottom="@dimen/_12sdp"
    app:cardBackgroundColor="@color/white"
    app:cardElevation="@dimen/_3sdp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/lightGray">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/_14sdp">

        <!-- ── Top row: vehicle icon + name + status badge ─────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Vehicle icon circle -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="@dimen/_42sdp"
                android:layout_height="@dimen/_42sdp"
                app:cardCornerRadius="@dimen/_21sdp"
                app:cardBackgroundColor="@color/lightGray"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/rideVehicleIcon"
                    android:layout_width="@dimen/_26sdp"
                    android:layout_height="@dimen/_26sdp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_bike"
                    app:tint="@color/darkPurple"
                    android:contentDescription="Vehicle" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Rider name & vehicle details -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/_10sdp">

                <TextView
                    android:id="@+id/rideRiderName"
                    style="@style/subtitle_style"
                    android:textStyle="bold"
                    android:textSize="@dimen/_13sdp"
                    android:layout_marginTop="0dp" />

                <TextView
                    android:id="@+id/rideVehicleNo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/_11sdp"
                    android:textColor="@color/darkGray"
                    android:layout_marginTop="@dimen/_2sdp" />

                <TextView
                    android:id="@+id/rideETA"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/_11sdp"
                    android:textColor="@color/green"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:layout_marginTop="@dimen/_2sdp" />

            </LinearLayout>

            <!-- Person Count badge -->
            <TextView
                android:id="@+id/ridePersonCountBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_6sdp"
                android:paddingHorizontal="@dimen/_8sdp"
                android:paddingVertical="@dimen/_4sdp"
                android:textSize="@dimen/_10sdp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:background="@drawable/bg_bottom_sheet_rounded"
                android:backgroundTint="@color/red" />

            <!-- Status badge -->
            <TextView
                android:id="@+id/rideStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/_8sdp"
                android:paddingVertical="@dimen/_4sdp"
                android:textSize="@dimen/_10sdp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:background="@drawable/bg_bottom_sheet_rounded"
                android:backgroundTint="@color/darkPurple" />

        </LinearLayout>

        <!-- Thin divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/lightGray"
            android:layout_marginVertical="@dimen/_10sdp" />

        <!-- ── From / To addresses ──────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Dot column -->
            <LinearLayout
                android:layout_width="@dimen/_14sdp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <!-- Green dot = pickup -->
                <View
                    android:layout_width="@dimen/_8sdp"
                    android:layout_height="@dimen/_8sdp"
                    android:background="@drawable/bg_bottom_sheet_rounded"
                    android:backgroundTint="@color/green" />

                <!-- Dashed line -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="@dimen/_18sdp"
                    android:background="@color/darkGray"
                    android:layout_marginVertical="@dimen/_2sdp" />

                <!-- Purple dot = destination -->
                <View
                    android:layout_width="@dimen/_8sdp"
                    android:layout_height="@dimen/_8sdp"
                    android:background="@drawable/bg_bottom_sheet_rounded"
                    android:backgroundTint="@color/darkPurple" />

            </LinearLayout>

            <!-- Address texts -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/_8sdp">

                <TextView
                    android:id="@+id/rideFromAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/_11sdp"
                    android:textColor="@color/darkGray"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/rideToAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/_11sdp"
                    android:textColor="@color/darkPurple"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="@dimen/_14sdp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Thin divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/lightGray"
            android:layout_marginVertical="@dimen/_10sdp" />

        <!-- ── Fare + Date row ──────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Fare -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fare"
                    android:textSize="@dimen/_10sdp"
                    android:textColor="@color/darkGray" />

                <TextView
                    android:id="@+id/rideFare"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/_13sdp"
                    android:textColor="@color/darkPurple"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Date & time -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Date"
                    android:textSize="@dimen/_10sdp"
                    android:textColor="@color/darkGray" />

                <TextView
                    android:id="@+id/rideDateTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/_11sdp"
                    android:textColor="@color/darkPurple" />

            </LinearLayout>

        </LinearLayout>

        <!-- ── Cancel button (visible for pending / accepted — before pickup) ─ -->
        <Button
            android:id="@+id/btnCancelRide"
            style="@style/btn_style"
            android:text="Cancel Booking"
            android:backgroundTint="@color/red"
            android:layout_marginTop="@dimen/_10sdp"
            android:visibility="gone" />

        <!-- ── Track Distance button (visible only for ongoing rides) ─ -->
        <Button
            android:id="@+id/btnTrackDistance"
            style="@style/btn_style"
            android:text="📍 Track Distance to Destination"
            android:layout_marginTop="@dimen/_10sdp"
            android:visibility="gone" />

        <!-- ── Pay Now button (visible when provider has picked up consumer) ── -->
        <Button
            android:id="@+id/btnPayNow"
            style="@style/btn_style"
            android:text="Pay Now"
            android:backgroundTint="@color/green"
            android:layout_marginTop="@dimen/_8sdp"
            android:visibility="gone" />

        <!-- ── Payment Done label (replaces Pay Now once consumer has paid) ── -->
        <TextView
            android:id="@+id/ridePaymentDoneLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Payment Done"
            android:textColor="@color/green"
            android:textStyle="bold"
            android:gravity="center"
            android:textSize="@dimen/_13sdp"
            android:layout_marginTop="@dimen/_8sdp"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
