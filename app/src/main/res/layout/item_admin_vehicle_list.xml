<?xml version="1.0" encoding="utf-8"?>
<!-- Vehicle List item card — shown in Admin Vehicle List screen -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/textbox_card_style"
    android:layout_marginHorizontal="@dimen/_15sdp"
    android:layout_marginBottom="@dimen/_10sdp"
    android:layout_marginTop="@dimen/_4sdp"
    app:cardBackgroundColor="@color/white"
    app:cardElevation="@dimen/_2sdp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/lightGray">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/_12sdp">

        <!-- Top row: vehicle icon + type + approved badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Vehicle icon circle -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="@dimen/_42sdp"
                android:layout_height="@dimen/_42sdp"
                app:cardCornerRadius="@dimen/_21sdp"
                app:cardBackgroundColor="@color/lightGray"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/vehicleIcon"
                    android:layout_width="@dimen/_26sdp"
                    android:layout_height="@dimen/_26sdp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_car"
                    app:tint="@color/darkPurple"
                    android:contentDescription="Vehicle" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Vehicle type + number -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/_10sdp">

                <TextView
                    android:id="@+id/vehicleType"
                    style="@style/subtitle_style"
                    android:textStyle="bold"
                    android:textSize="@dimen/_13sdp"
                    android:layout_marginTop="0dp"
                    android:text="Car" />

                <TextView
                    android:id="@+id/vehicleNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/_11sdp"
                    android:textColor="@color/darkGray"
                    android:layout_marginTop="@dimen/_2sdp"
                    android:text="GJ 01 AB 1234" />

                <TextView
                    android:id="@+id/vehicleSeats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/_10sdp"
                    android:textColor="@color/darkPurple"
                    android:textStyle="bold"
                    android:layout_marginTop="@dimen/_2sdp"
                    android:text="4 Seats" />

                <TextView
                    android:id="@+id/vehiclePrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/_10sdp"
                    android:textColor="@color/darkPurple"
                    android:textStyle="bold"
                    android:layout_marginTop="@dimen/_2sdp"
                    android:text="₹0.0 / KM"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Badges: Status + Purpose -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <!-- Status badge (Pending / Approved) -->
                <TextView
                    android:id="@+id/statusBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/_8sdp"
                    android:paddingVertical="@dimen/_4sdp"
                    android:textSize="@dimen/_9sdp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:text="Approved"
                    android:layout_marginBottom="@dimen/_4sdp"
                    android:background="@drawable/bg_bottom_sheet_rounded"
                    android:backgroundTint="@color/green" />

                <!-- Purpose badge (Rent / Ride) -->
                <TextView
                    android:id="@+id/vehiclePurpose"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/_8sdp"
                    android:paddingVertical="@dimen/_4sdp"
                    android:textSize="@dimen/_10sdp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:text="For Ride"
                    android:background="@drawable/bg_bottom_sheet_rounded"
                    android:backgroundTint="@color/darkPurple" />

            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/lightGray"
            android:layout_marginVertical="@dimen/_10sdp" />

        <!-- Owner info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Owner"
                    android:textSize="@dimen/_10sdp"
                    android:textColor="@color/darkGray" />

                <TextView
                    android:id="@+id/vehicleOwner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/_11sdp"
                    android:textColor="@color/darkPurple"
                    android:textStyle="bold"
                    android:layout_marginTop="@dimen/_2sdp"
                    android:text="Owner Name" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Approved On"
                    android:textSize="@dimen/_10sdp"
                    android:textColor="@color/darkGray" />

                <TextView
                    android:id="@+id/approvedDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/_11sdp"
                    android:textColor="@color/darkPurple"
                    android:textStyle="bold"
                    android:layout_marginTop="@dimen/_2sdp"
                    android:text="01 Jan 2025" />

            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/lightGray"
            android:layout_marginVertical="@dimen/_10sdp" />

        <!-- View RC Document button — same style as Admin Vehicle Requests -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/_4sdp"
            app:cardCornerRadius="@dimen/_8sdp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/lightGray">

            <LinearLayout
                android:id="@+id/viewRcDocument"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="@dimen/_8sdp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="@dimen/_14sdp"
                    android:layout_height="@dimen/_14sdp"
                    android:src="@drawable/ic_upload"
                    app:tint="@color/darkPurple"
                    android:layout_marginEnd="@dimen/_4sdp"
                    android:contentDescription="RC Document" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View RC Document"
                    android:textSize="@dimen/_11sdp"
                    android:textColor="@color/darkPurple"
                    android:textStyle="bold" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
