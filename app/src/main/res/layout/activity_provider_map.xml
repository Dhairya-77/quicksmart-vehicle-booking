<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Full-screen map -->
    <fragment
        android:id="@+id/mapView"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top search bar -->
    <LinearLayout
        android:id="@+id/searchBarContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentTop="true"
        android:padding="@dimen/_15sdp">

        <androidx.cardview.widget.CardView
            style="@style/textbox_card_style"
            app:cardBackgroundColor="@color/white"
            app:cardElevation="@dimen/_4sdp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/_8sdp">

                <!-- Back / Home icon -->
                <ImageView
                    android:id="@+id/backButton"
                    android:layout_width="@dimen/_28sdp"
                    android:layout_height="@dimen/_28sdp"
                    android:src="@drawable/ic_home"
                    app:tint="@color/darkPurple"
                    android:contentDescription="Back"
                    android:padding="@dimen/_3sdp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="@dimen/_20sdp"
                    android:background="@color/lightGray"
                    android:layout_marginHorizontal="@dimen/_8sdp" />

                <EditText
                    android:id="@+id/destinationInput"
                    style="@style/textbox_style"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:background="@null"
                    android:padding="@dimen/_4sdp"
                    android:hint="Search destination…"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:maxLines="1"
                    android:singleLine="true" />

                <ImageView
                    android:id="@+id/clearDestinationButton"
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="@color/darkGray"
                    android:contentDescription="Clear"
                    android:visibility="gone"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Long-press hint chip -->
        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_8sdp"
            app:cardCornerRadius="@dimen/_20sdp"
            app:cardElevation="@dimen/_3sdp"
            app:cardBackgroundColor="@color/darkPurple">

            <TextView
                style="@style/subtitle_style"
                android:paddingHorizontal="@dimen/_12sdp"
                android:paddingVertical="@dimen/_6sdp"
                android:text="Long-press map to set destination 📍"
                android:textColor="@color/white"
                android:layout_marginTop="0dp" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- ── FAB column (right side, below search bar) ── -->

    <!-- My Location FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/myLocationFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_below="@id/searchBarContainer"
        android:layout_marginEnd="@dimen/_15sdp"
        android:contentDescription="My Location"
        android:src="@drawable/ic_locate"
        app:backgroundTint="@color/white"
        app:elevation="@dimen/_6sdp"
        app:fabSize="mini"
        app:tint="@color/darkPurple" />

    <!-- Bookings FAB with badge -->
    <FrameLayout
        android:id="@+id/bookingsFabContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_below="@id/myLocationFab"
        android:layout_marginEnd="@dimen/_15sdp"
        android:layout_marginTop="@dimen/_10sdp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/bookingsFab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="Ride Bookings"
            android:src="@drawable/ic_bookings"
            app:backgroundTint="@color/darkPurple"
            app:elevation="@dimen/_6sdp"
            app:fabSize="mini"
            app:tint="@color/white" />

        <!-- Circular badge -->
        <TextView
            android:id="@+id/bookingsBadge"
            android:layout_width="@dimen/_16sdp"
            android:layout_height="@dimen/_16sdp"
            android:layout_gravity="top|end"
            android:background="@drawable/bg_badge_circle"
            android:gravity="center"
            android:text="0"
            android:textColor="@color/white"
            android:textSize="@dimen/_8sdp"
            android:textStyle="bold"
            android:elevation="@dimen/_8sdp"
            android:translationZ="@dimen/_2sdp"
            android:layout_marginTop="-4dp"
            android:layout_marginEnd="-4dp"
            android:visibility="gone"/>

    </FrameLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/rideSettingsFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_below="@id/bookingsFabContainer"
        android:layout_marginEnd="@dimen/_15sdp"
        android:layout_marginTop="@dimen/_10sdp"
        android:contentDescription="Ride Settings"
        android:src="@drawable/ic_edit"
        app:backgroundTint="@color/white"
        app:elevation="@dimen/_6sdp"
        app:fabSize="mini"
        app:tint="@color/darkPurple" />

</RelativeLayout>
