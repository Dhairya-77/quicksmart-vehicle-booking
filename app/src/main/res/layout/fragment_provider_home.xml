<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/_15sdp">

        <!-- Greeting Title -->
        <TextView
            android:id="@+id/welcomeTitle"
            style="@style/title_style"
            android:text="Welcome back, Provider"
            android:layout_marginBottom="@dimen/_15sdp" />

        <!-- ── Instance Ride Section ── -->
        <TextView
            style="@style/subtitle_style"
            android:text="Instant Ride"
            android:textStyle="bold"
            android:textSize="@dimen/_14sdp"
            android:layout_marginBottom="@dimen/_10sdp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardInstanceRide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/_20sdp"
            app:cardBackgroundColor="@color/darkPurple"
            app:cardCornerRadius="@dimen/_12sdp"
            app:cardElevation="@dimen/_4sdp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/_15sdp">

                <!-- Icon -->
                <ImageView
                    android:layout_width="@dimen/_48sdp"
                    android:layout_height="@dimen/_48sdp"
                    android:src="@drawable/ic_car"
                    app:tint="@color/white"
                    android:layout_marginEnd="@dimen/_15sdp"
                    android:contentDescription="Instance Ride" />

                <!-- Text block -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Instant Ride"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_15sdp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Manage live ride requests"
                        android:textColor="@color/transparentWhite"
                        android:textSize="@dimen/_11sdp"
                        android:layout_marginTop="@dimen/_3sdp" />

                </LinearLayout>

                <!-- Arrow -->
                <ImageView
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:src="@drawable/ic_right_arrow"
                    app:tint="@color/white"
                    android:contentDescription="Go" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── Rental Bookings Section Title ── -->
        <TextView
            style="@style/subtitle_style"
            android:text="Rental Bookings"
            android:textStyle="bold"
            android:textSize="@dimen/_14sdp"
            android:layout_marginBottom="@dimen/_10sdp" />

        <!-- Rental Request + Rental Bookings row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="@dimen/_20sdp">

            <!-- Rental Request Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRentalRequest"
                style="@style/square_card_style"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/_8sdp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="@dimen/_15sdp">

                    <!-- Icon with circular badge -->
                    <FrameLayout
                        android:layout_width="@dimen/_40sdp"
                        android:layout_height="@dimen/_40sdp"
                        android:layout_marginBottom="@dimen/_8sdp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_rental_request"
                            app:tint="@color/darkPurple"
                            android:contentDescription="Rental Request" />

                        <!-- Circular badge -->
                        <TextView
                            android:id="@+id/rentalRequestBadge"
                            android:layout_width="@dimen/_18sdp"
                            android:layout_height="@dimen/_18sdp"
                            android:layout_gravity="top|end"
                            android:background="@drawable/bg_badge_circle"
                            android:gravity="center"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textSize="@dimen/_9sdp"
                            android:textStyle="bold"
                            android:visibility="gone" />

                    </FrameLayout>

                    <TextView
                        style="@style/subtitle_style"
                        android:text="Rental Request"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginTop="0dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Rental Bookings Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRentalBookings"
                style="@style/square_card_style"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/_8sdp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="@dimen/_15sdp">

                    <ImageView
                        android:layout_width="@dimen/_40sdp"
                        android:layout_height="@dimen/_40sdp"
                        android:src="@drawable/ic_bookings"
                        app:tint="@color/darkPurple"
                        android:layout_marginBottom="@dimen/_8sdp"
                        android:contentDescription="Rental Bookings" />

                    <TextView
                        style="@style/subtitle_style"
                        android:text="Rental Bookings"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginTop="0dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- ── Vehicle Section Title ── -->
        <TextView
            style="@style/subtitle_style"
            android:text="Vehicle"
            android:textStyle="bold"
            android:textSize="@dimen/_14sdp"
            android:layout_marginBottom="@dimen/_10sdp" />

        <!-- Add Vehicle + Vehicle List row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="@dimen/_20sdp">

            <!-- Add Vehicle Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAddVehicle"
                style="@style/square_card_style"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/_8sdp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="@dimen/_15sdp">

                    <ImageView
                        android:layout_width="@dimen/_40sdp"
                        android:layout_height="@dimen/_40sdp"
                        android:src="@drawable/ic_add_vehicle"
                        app:tint="@color/darkPurple"
                        android:layout_marginBottom="@dimen/_8sdp"
                        android:contentDescription="Add Vehicle" />

                    <TextView
                        style="@style/subtitle_style"
                        android:text="Add Vehicle"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginTop="0dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Vehicle List Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardVehicleList"
                style="@style/square_card_style"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/_8sdp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/_15sdp">

                    <ImageView
                        android:layout_width="@dimen/_40sdp"
                        android:layout_height="@dimen/_40sdp"
                        android:layout_marginBottom="@dimen/_8sdp"
                        android:contentDescription="Vehicle List"
                        android:src="@drawable/ic_vehicle_list"
                        app:tint="@color/darkPurple" />

                    <TextView
                        style="@style/subtitle_style"
                        android:layout_marginTop="0dp"
                        android:gravity="center"
                        android:text="Vehicle List"
                        android:textStyle="bold" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
