<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/textbox_card_style"
    android:layout_marginHorizontal="@dimen/_12sdp"
    android:layout_marginBottom="@dimen/_8sdp"
    app:cardBackgroundColor="@color/lightGray"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/_12sdp">

        <!-- Vehicle Icon -->
        <ImageView
            android:id="@+id/riderVehicleIcon"
            android:layout_width="@dimen/_38sdp"
            android:layout_height="@dimen/_38sdp"
            android:src="@drawable/ic_bike"
            app:tint="@color/darkPurple"
            android:contentDescription="Vehicle" />

        <!-- Rider Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/_10sdp">

            <!-- Rider name -->
            <TextView
                android:id="@+id/riderName"
                style="@style/subtitle_style"
                android:textStyle="bold"
                android:layout_marginTop="0dp" />

            <!-- Vehicle number -->
            <TextView
                android:id="@+id/riderVehicleNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/_11sdp"
                android:textColor="@color/darkGray" />

        </LinearLayout>

        <!-- Price + ETA + Passenger count on right -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <!-- Per-person rate -->
            <TextView
                android:id="@+id/riderPrice"
                style="@style/subtitle_style"
                android:textStyle="bold"
                android:textColor="@color/darkPurple"
                android:layout_marginTop="0dp" />

            <!-- ETA -->
            <TextView
                android:id="@+id/riderEta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/_11sdp"
                android:textColor="@color/darkGray" />

            <!-- Passenger occupancy (e.g. "2/3 seats") — hidden for bike -->
            <TextView
                android:id="@+id/riderPassengerCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/_11sdp"
                android:textColor="@color/darkGray"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
