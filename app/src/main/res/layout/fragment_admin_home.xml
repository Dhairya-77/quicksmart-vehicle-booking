<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/_15sdp">

            <!-- ── Monthly Stats Section Title ── -->
            <TextView
                style="@style/subtitle_style"
                android:text="Monthly Overview"
                android:textStyle="bold"
                android:textSize="@dimen/_14sdp"
                android:layout_marginBottom="@dimen/_10sdp" />

            <!-- ── Monthly Earnings Card ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMonthlyEarnings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/_10sdp"
                app:cardBackgroundColor="@color/darkPurple"
                app:cardCornerRadius="@dimen/_12sdp"
                app:cardElevation="@dimen/_4sdp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/_15sdp">

                    <!-- Icon background circle -->
                    <FrameLayout
                        android:layout_width="@dimen/_48sdp"
                        android:layout_height="@dimen/_48sdp"
                        android:layout_marginEnd="@dimen/_15sdp"
                        android:background="@color/transparentWhite"
                        android:backgroundTint="@color/lightPurple">

                        <ImageView
                            android:layout_width="@dimen/_28sdp"
                            android:layout_height="@dimen/_28sdp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_wallet"
                            app:tint="@color/white"
                            android:contentDescription="Monthly Earnings" />
                    </FrameLayout>

                    <!-- Text block -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Monthly Earnings"
                            android:textColor="@color/transparentWhite"
                            android:textSize="@dimen/_11sdp" />

                        <TextView
                            android:id="@+id/monthlyEarnings"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹ 0.00"
                            android:textColor="@color/white"
                            android:textSize="@dimen/_20sdp"
                            android:textStyle="bold"
                            android:layout_marginTop="@dimen/_3sdp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── Instant Ride Bookings + Rent Bookings row ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:layout_marginBottom="@dimen/_20sdp">

                <!-- Monthly Instant Ride Bookings -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMonthlyInstantRide"
                    style="@style/square_card_style"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/_8sdp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/_8sdp">

                        <ImageView
                            android:layout_width="@dimen/_32sdp"
                            android:layout_height="@dimen/_32sdp"
                            android:src="@drawable/ic_car"
                            app:tint="@color/darkPurple"
                            android:layout_marginBottom="@dimen/_6sdp"
                            android:contentDescription="Instant Rides" />

                        <TextView
                            android:id="@+id/instantRideCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/darkPurple"
                            android:textSize="@dimen/_18sdp"
                            android:textStyle="bold" />

                        <TextView
                            style="@style/subtitle_style"
                            android:text="Instant Rides"
                            android:gravity="center"
                            android:layout_marginTop="@dimen/_3sdp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Monthly Rent Vehicle Bookings -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMonthlyRentBooking"
                    style="@style/square_card_style"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/_8sdp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/_8sdp">

                        <ImageView
                            android:layout_width="@dimen/_32sdp"
                            android:layout_height="@dimen/_32sdp"
                            android:src="@drawable/ic_rental_request"
                            app:tint="@color/darkPurple"
                            android:layout_marginBottom="@dimen/_6sdp"
                            android:contentDescription="Rent Bookings" />

                        <TextView
                            android:id="@+id/rentBookingCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/darkPurple"
                            android:textSize="@dimen/_18sdp"
                            android:textStyle="bold" />

                        <TextView
                            style="@style/subtitle_style"
                            android:text="Rent Bookings"
                            android:gravity="center"
                            android:layout_marginTop="@dimen/_3sdp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ── Activity Section Title ── -->
            <TextView
                style="@style/subtitle_style"
                android:text="Activities"
                android:textStyle="bold"
                android:textSize="@dimen/_14sdp"
                android:layout_marginBottom="@dimen/_10sdp" />

            <!-- ── Provider Request Card ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardProviderRequest"
                style="@style/textbox_card_style"
                android:layout_marginBottom="@dimen/_10sdp"
                app:cardBackgroundColor="@color/lightGray"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_56sdp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/_12sdp"
                    android:paddingEnd="@dimen/_12sdp">

                    <!-- Icon with circular badge -->
                    <FrameLayout
                        android:layout_width="@dimen/_34sdp"
                        android:layout_height="@dimen/_34sdp"
                        android:layout_marginEnd="@dimen/_12sdp">

                        <ImageView
                            android:layout_width="@dimen/_23sdp"
                            android:layout_height="@dimen/_23sdp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_person"
                            app:tint="@color/darkPurple"
                            android:contentDescription="Provider Request" />

                        <!-- Circular badge -->
                        <TextView
                            android:id="@+id/providerRequestBadge"
                            android:layout_width="@dimen/_16sdp"
                            android:layout_height="@dimen/_16sdp"
                            android:layout_gravity="top|end"
                            android:background="@drawable/bg_badge_circle"
                            android:gravity="center"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textSize="@dimen/_8sdp"
                            android:textStyle="bold"
                            android:visibility="gone" />

                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Provider Requests"
                        android:textColor="@color/darkPurple"
                        android:textSize="@dimen/_14sdp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="@dimen/_20sdp"
                        android:layout_height="@dimen/_20sdp"
                        android:src="@drawable/ic_right_arrow"
                        android:contentDescription="Go" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ── Provider List Card ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardProviderList"
                style="@style/textbox_card_style"
                android:layout_marginBottom="@dimen/_10sdp"
                app:cardBackgroundColor="@color/lightGray"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_56sdp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/_12sdp"
                    android:paddingEnd="@dimen/_12sdp">

                    <ImageView
                        android:layout_width="@dimen/_30sdp"
                        android:layout_height="@dimen/_30sdp"
                        android:src="@drawable/ic_person_list"
                        app:tint="@color/darkPurple"
                        android:contentDescription="Provider List"
                        android:layout_marginEnd="@dimen/_16sdp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="List of Providers"
                        android:textColor="@color/darkPurple"
                        android:textSize="@dimen/_14sdp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="@dimen/_20sdp"
                        android:layout_height="@dimen/_20sdp"
                        android:src="@drawable/ic_right_arrow"
                        android:contentDescription="Go" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ── Vehicle Request Card ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardVehicleRequest"
                style="@style/textbox_card_style"
                android:layout_marginBottom="@dimen/_10sdp"
                app:cardBackgroundColor="@color/lightGray"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_56sdp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/_12sdp"
                    android:paddingEnd="@dimen/_12sdp">

                    <!-- Icon with circular badge -->
                    <FrameLayout
                        android:layout_width="@dimen/_34sdp"
                        android:layout_height="@dimen/_34sdp"
                        android:layout_marginEnd="@dimen/_12sdp">

                        <ImageView
                            android:layout_width="@dimen/_26sdp"
                            android:layout_height="@dimen/_26sdp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_add_vehicle"
                            app:tint="@color/darkPurple"
                            android:contentDescription="Vehicle Request" />

                        <!-- Circular badge -->
                        <TextView
                            android:id="@+id/vehicleRequestBadge"
                            android:layout_width="@dimen/_16sdp"
                            android:layout_height="@dimen/_16sdp"
                            android:layout_gravity="top|end"
                            android:background="@drawable/bg_badge_circle"
                            android:gravity="center"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textSize="@dimen/_8sdp"
                            android:textStyle="bold"
                            android:visibility="gone" />

                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Vehicle Requests"
                        android:textColor="@color/darkPurple"
                        android:textSize="@dimen/_14sdp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="@dimen/_20sdp"
                        android:layout_height="@dimen/_20sdp"
                        android:src="@drawable/ic_right_arrow"
                        android:contentDescription="Go" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ── Vehicle List Card ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAdminVehicleList"
                style="@style/textbox_card_style"
                android:layout_marginBottom="@dimen/_20sdp"
                app:cardBackgroundColor="@color/lightGray"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_56sdp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/_12sdp"
                    android:paddingEnd="@dimen/_12sdp">

                    <ImageView
                        android:layout_width="@dimen/_26sdp"
                        android:layout_height="@dimen/_26sdp"
                        android:src="@drawable/ic_vehicle_list"
                        app:tint="@color/darkPurple"
                        android:contentDescription="Vehicle List"
                        android:layout_marginEnd="@dimen/_16sdp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Vehicle List"
                        android:textColor="@color/darkPurple"
                        android:textSize="@dimen/_14sdp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="@dimen/_20sdp"
                        android:layout_height="@dimen/_20sdp"
                        android:src="@drawable/ic_right_arrow"
                        android:contentDescription="Go" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Centered circular ProgressBar overlay (shown while Firebase data loads) -->
    <ProgressBar
        android:id="@+id/homeProgress"
        android:layout_width="@dimen/_42sdp"
        android:layout_height="@dimen/_42sdp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/darkPurple"
        android:visibility="gone" />

</FrameLayout>
