<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/_15sdp">

        <!-- ── Avatar + User Info ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="@dimen/_20sdp">

            <!-- Circular avatar with CircleImageView -->
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/img_avatar"
                android:layout_width="@dimen/_90sdp"
                android:layout_height="@dimen/_90sdp"
                android:src="@drawable/ic_person"
                android:padding="5dp"
                android:background="@drawable/bg_circle_border" />

            <!-- Name -->
            <TextView
                android:id="@+id/name"
                style="@style/subtitle_style"
                android:layout_marginTop="@dimen/_10sdp"
                android:text="name"
                android:textColor="@color/darkPurple"
                android:textStyle="bold"
                android:textSize="@dimen/_14sdp" />

        </LinearLayout>

        <!-- ── Menu Items ── -->

        <!-- Profile -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_profile_edit"
            style="@style/textbox_card_style"
            android:layout_marginBottom="@dimen/_10sdp"
            app:cardBackgroundColor="@color/lightGray"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/_50sdp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/_12sdp"
                android:paddingEnd="@dimen/_12sdp">

                <ImageView
                    android:layout_width="@dimen/_22sdp"
                    android:layout_height="@dimen/_22sdp"
                    android:src="@drawable/ic_person"
                    app:tint="@color/darkPurple"
                    android:contentDescription="Profile"
                    android:layout_marginEnd="@dimen/_12sdp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Edit Profile"
                    android:textColor="@color/darkPurple"
                    android:textSize="@dimen/_14sdp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:src="@drawable/ic_right_arrow"
                    android:contentDescription="Go" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Booking History -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_booking_history"
            style="@style/textbox_card_style"
            android:layout_marginBottom="@dimen/_10sdp"
            app:cardBackgroundColor="@color/lightGray"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/_50sdp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/_12sdp"
                android:paddingEnd="@dimen/_12sdp">

                <ImageView
                    android:layout_width="@dimen/_22sdp"
                    android:layout_height="@dimen/_22sdp"
                    android:src="@drawable/ic_history"
                    app:tint="@color/darkPurple"
                    android:contentDescription="Booking History"
                    android:layout_marginEnd="@dimen/_12sdp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Booking History"
                    android:textColor="@color/darkPurple"
                    android:textSize="@dimen/_14sdp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:src="@drawable/ic_right_arrow"
                    android:contentDescription="Go" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Transaction History -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_transaction_history"
            style="@style/textbox_card_style"
            android:layout_marginBottom="@dimen/_10sdp"
            app:cardBackgroundColor="@color/lightGray"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/_50sdp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/_12sdp"
                android:paddingEnd="@dimen/_12sdp">

                <ImageView
                    android:layout_width="@dimen/_22sdp"
                    android:layout_height="@dimen/_22sdp"
                    android:src="@drawable/ic_transaction"
                    app:tint="@color/darkPurple"
                    android:contentDescription="Transaction History"
                    android:layout_marginEnd="@dimen/_12sdp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Transaction History"
                    android:textColor="@color/darkPurple"
                    android:textSize="@dimen/_14sdp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:src="@drawable/ic_right_arrow"
                    android:contentDescription="Go" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Consumer Policy -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_term_and_con"
            style="@style/textbox_card_style"
            android:layout_marginBottom="@dimen/_20sdp"
            app:cardBackgroundColor="@color/lightGray"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/_50sdp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/_12sdp"
                android:paddingEnd="@dimen/_12sdp">

                <ImageView
                    android:layout_width="@dimen/_22sdp"
                    android:layout_height="@dimen/_22sdp"
                    android:src="@drawable/ic_policy"
                    app:tint="@color/darkPurple"
                    android:contentDescription="Consumer Policy"
                    android:layout_marginEnd="@dimen/_12sdp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Terms &amp; Conditions"
                    android:textColor="@color/darkPurple"
                    android:textSize="@dimen/_14sdp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:src="@drawable/ic_right_arrow"
                    android:contentDescription="Go" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ── Logout Card (red) ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_logout"
            style="@style/textbox_card_style"
            android:layout_marginBottom="@dimen/_20sdp"
            app:cardBackgroundColor="@color/lightGray"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/_50sdp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/_12sdp"
                android:paddingEnd="@dimen/_12sdp">

                <ImageView
                    android:layout_width="@dimen/_22sdp"
                    android:layout_height="@dimen/_22sdp"
                    android:src="@drawable/ic_logout"
                    android:layout_marginEnd="@dimen/_12sdp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Logout"
                    android:textColor="@color/red"
                    android:textSize="@dimen/_14sdp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:src="@drawable/ic_right_arrow"
                    app:tint="@color/red" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
