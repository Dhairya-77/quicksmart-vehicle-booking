<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Full-screen map -->
    <fragment
        android:id="@+id/mapView"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top search bar — anchored to top -->
    <LinearLayout
        android:id="@+id/searchBarContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentTop="true"
        android:padding="@dimen/_15sdp">

        <!-- Search input card -->
        <androidx.cardview.widget.CardView
            style="@style/textbox_card_style"
            app:cardBackgroundColor="@color/white"
            app:cardElevation="@dimen/_4sdp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/_8sdp">

                <!-- Back arrow -->
                <ImageView
                    android:id="@+id/backButton"
                    android:layout_width="@dimen/_28sdp"
                    android:layout_height="@dimen/_28sdp"
                    android:src="@drawable/ic_home"
                    app:tint="@color/darkPurple"
                    android:contentDescription="Back"
                    android:padding="@dimen/_3sdp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <!-- Divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="@dimen/_20sdp"
                    android:background="@color/lightGray"
                    android:layout_marginHorizontal="@dimen/_8sdp" />

                <!-- Destination search field -->
                <EditText
                    android:id="@+id/destinationInput"
                    style="@style/textbox_style"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:background="@null"
                    android:padding="@dimen/_4sdp"
                    android:hint="Where do you want to go?"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:maxLines="1"
                    android:singleLine="true" />

                <!-- Clear button -->
                <ImageView
                    android:id="@+id/clearDestinationButton"
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="@color/darkGray"
                    android:contentDescription="Clear"
                    android:visibility="gone"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- "Pin on map" hint  -->
        <androidx.cardview.widget.CardView
            android:id="@+id/pinHintChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_8sdp"
            app:cardCornerRadius="@dimen/_20sdp"
            app:cardElevation="@dimen/_3sdp"
            app:cardBackgroundColor="@color/darkPurple">

            <TextView
                style="@style/subtitle_style"
                android:paddingHorizontal="@dimen/_12sdp"
                android:paddingVertical="@dimen/_6sdp"
                android:text="long-press on map to drop a pin📍"
                android:textColor="@color/white"
                android:layout_marginTop="0dp" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- My Location FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/myLocationFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_below="@id/searchBarContainer"
        android:layout_marginEnd="@dimen/_15sdp"
        android:contentDescription="My Location"
        android:src="@drawable/ic_locate"
        app:backgroundTint="@color/white"
        app:elevation="@dimen/_6sdp"
        app:fabSize="mini"
        app:tint="@color/darkPurple" />

    <!-- Confirm destination bar -->
    <LinearLayout
        android:id="@+id/confirmDestinationPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentBottom="true"
        android:visibility="gone"
        android:layout_marginBottom="@dimen/_15sdp"
        android:layout_marginHorizontal="@dimen/_15sdp">

        <!-- Confirm card -->
        <androidx.cardview.widget.CardView
            style="@style/textbox_card_style"
            app:cardBackgroundColor="@color/white"
            app:cardElevation="@dimen/_6sdp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/_15sdp">

                <!-- "Going to" label -->
                <TextView
                    style="@style/subtitle_style"
                    android:text="Going to"
                    android:layout_marginTop="0dp" />

                <!-- Selected address in title style -->
                <TextView
                    android:id="@+id/selectedDestinationText"
                    style="@style/title_style"
                    android:textSize="@dimen/_15sdp"
                    android:text="—"
                    android:ellipsize="end"
                    android:maxLines="2" />

                <!-- Confirm button -->
                <Button
                    android:id="@+id/confirmDestinationButton"
                    style="@style/btn_style"
                    android:text="Confirm &amp; See Vehicles"
                    android:layout_marginTop="@dimen/_12sdp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</RelativeLayout>
