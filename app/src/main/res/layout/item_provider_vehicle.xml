<?xml version="1.0" encoding="utf-8"?>
<!--  Each vehicle card in the provider's vehicle list  -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/textbox_card_style"
    android:layout_marginHorizontal="@dimen/_15sdp"
    android:layout_marginBottom="@dimen/_10sdp"
    android:layout_marginTop="@dimen/_4sdp"
    app:cardBackgroundColor="@color/white"
    app:cardElevation="@dimen/_2sdp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/lightGray">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/_12sdp">

        <!-- Top row: icon + vehicle info + purpose badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Icon circle -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="@dimen/_42sdp"
                android:layout_height="@dimen/_42sdp"
                app:cardCornerRadius="@dimen/_21sdp"
                app:cardBackgroundColor="@color/lightGray"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/vehicle_icon"
                    android:layout_width="@dimen/_26sdp"
                    android:layout_height="@dimen/_26sdp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_car"
                    app:tint="@color/darkPurple"
                    android:contentDescription="Vehicle" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Vehicle type + number -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/_10sdp">

                <TextView
                    android:id="@+id/vehicle_type_label"
                    style="@style/subtitle_style"
                    android:textStyle="bold"
                    android:textSize="@dimen/_13sdp"
                    android:layout_marginTop="0dp" />

                <TextView
                    android:id="@+id/vehicle_number_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/_11sdp"
                    android:textColor="@color/darkGray"
                    android:layout_marginTop="@dimen/_2sdp" />

                <TextView
                    android:id="@+id/vehicle_seats_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/_10sdp"
                    android:textColor="@color/darkPurple"
                    android:textStyle="bold"
                    android:layout_marginTop="@dimen/_2sdp"
                    android:text="2 Seats" />

            </LinearLayout>

            <!-- Badges: Status + Purpose -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <!-- Status badge (Pending / Approved) -->
                <TextView
                    android:id="@+id/vehicle_status_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/_8sdp"
                    android:paddingVertical="@dimen/_4sdp"
                    android:textSize="@dimen/_9sdp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:text="Pending"
                    android:layout_marginBottom="@dimen/_4sdp"
                    android:background="@drawable/bg_bottom_sheet_rounded"
                    android:backgroundTint="@color/green" />

                <!-- Purpose badge (Rent / Ride) -->
                <TextView
                    android:id="@+id/vehicle_purpose_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/_8sdp"
                    android:paddingVertical="@dimen/_4sdp"
                    android:textSize="@dimen/_10sdp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:background="@drawable/bg_bottom_sheet_rounded"
                    android:backgroundTint="@color/darkPurple" />

            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/lightGray"
            android:layout_marginVertical="@dimen/_10sdp" />

        <!-- Pricing Edit (NEW) — only for Rental -->
        <LinearLayout
            android:id="@+id/layout_pricing_edit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/_10sdp"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Rent Price / KM"
                android:textSize="@dimen/_11sdp"
                android:textColor="@color/darkGray" />

            <androidx.cardview.widget.CardView
                style="@style/textbox_card_style"
                android:layout_width="@dimen/_80sdp"
                app:cardCornerRadius="@dimen/_6sdp"
                app:cardBackgroundColor="@color/lightGray">

                <EditText
                    android:id="@+id/vehicle_edit_price_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/_6sdp"
                    android:textSize="@dimen/_11sdp"
                    android:textColor="@color/darkPurple"
                    android:textStyle="bold"
                    android:background="@null"
                    android:hint="0.0"
                    android:inputType="numberDecimal"
                    android:gravity="center"
                    android:imeOptions="actionDone" />

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Edit purpose + Delete row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:baselineAligned="false">

            <!-- Edit purpose spinner -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginEnd="@dimen/_8sdp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Change Purpose"
                    android:textSize="@dimen/_10sdp"
                    android:textColor="@color/darkGray"
                    android:layout_marginBottom="@dimen/_4sdp" />

                <androidx.cardview.widget.CardView
                    style="@style/textbox_card_style"
                    app:cardCornerRadius="@dimen/_8sdp"
                    app:cardBackgroundColor="@color/lightGray">

                    <Spinner
                        android:id="@+id/vehicle_edit_purpose_spinner"
                        style="@style/spinner_style"
                        android:paddingHorizontal="@dimen/_8sdp"
                        android:paddingVertical="@dimen/_6sdp" />

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Delete button -->
            <Button
                android:id="@+id/btn_delete_vehicle"
                style="@style/btn_style"
                android:layout_width="wrap_content"
                android:layout_marginTop="0dp"
                android:text="Delete"
                android:backgroundTint="@color/red" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
