<?xml version="1.0" encoding="utf-8"?>
<!-- Accepted ride item: locate + call on LEFT, consumer info in middle, Pickup/Complete on RIGHT -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/textbox_card_style"
    android:layout_marginHorizontal="@dimen/_15sdp"
    android:layout_marginBottom="@dimen/_8sdp"
    android:layout_marginTop="@dimen/_2sdp"
    app:cardBackgroundColor="@color/white"
    app:cardElevation="@dimen/_2sdp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/lightGray">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/_10sdp">

        <!-- Top Row: locate + call icons | consumer info | status badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- LEFT: locate + call icons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginEnd="@dimen/_10sdp">

                <!-- Locate -->
                <androidx.cardview.widget.CardView
                    android:layout_width="@dimen/_32sdp"
                    android:layout_height="@dimen/_32sdp"
                    app:cardCornerRadius="@dimen/_8sdp"
                    app:cardBackgroundColor="@color/lightGray"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="@dimen/_6sdp">

                    <ImageView
                        android:id="@+id/accepted_locate_btn"
                        android:layout_width="@dimen/_18sdp"
                        android:layout_height="@dimen/_18sdp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_action_locate"
                        app:tint="@color/darkPurple"
                        android:contentDescription="Locate consumer"
                        android:clickable="true"
                        android:focusable="true" />

                </androidx.cardview.widget.CardView>

                <!-- Call -->
                <androidx.cardview.widget.CardView
                    android:layout_width="@dimen/_32sdp"
                    android:layout_height="@dimen/_32sdp"
                    app:cardCornerRadius="@dimen/_8sdp"
                    app:cardBackgroundColor="@color/lightGray"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/accepted_call_btn"
                        android:layout_width="@dimen/_18sdp"
                        android:layout_height="@dimen/_18sdp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_action_call"
                        app:tint="@color/green"
                        android:contentDescription="Call consumer"
                        android:clickable="true"
                        android:focusable="true" />

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Consumer info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/accepted_consumer_name"
                    style="@style/subtitle_style"
                    android:textStyle="bold"
                    android:textSize="@dimen/_13sdp"
                    android:layout_marginTop="0dp" />

                <TextView
                    android:id="@+id/accepted_pickup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/_11sdp"
                    android:textColor="@color/darkGray"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="@dimen/_2sdp" />

                <TextView
                    android:id="@+id/accepted_destination"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/_11sdp"
                    android:textColor="@color/darkPurple"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="@dimen/_2sdp" />

            </LinearLayout>

            <!-- Status and Badge Column -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <!-- Status badge -->
                <TextView
                    android:id="@+id/accepted_status_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_4sdp"
                    android:text="Accepted"
                    android:paddingHorizontal="@dimen/_6sdp"
                    android:paddingVertical="@dimen/_3sdp"
                    android:textSize="@dimen/_10sdp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:background="@drawable/bg_bottom_sheet_rounded"
                    android:backgroundTint="@color/darkPurple" />

                <!-- Person Count badge -->
                <TextView
                    android:id="@+id/accepted_person_count_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/_6sdp"
                    android:paddingVertical="@dimen/_3sdp"
                    android:layout_marginTop="@dimen/_3sdp"
                    android:textSize="@dimen/_10sdp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:background="@drawable/bg_bottom_sheet_rounded"
                    android:backgroundTint="@color/red" />


            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/lightGray"
            android:layout_marginTop="@dimen/_8sdp"
            android:layout_marginBottom="@dimen/_6sdp" />

        <!-- Action buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Payment status label (shown only when status = picked_up) -->
            <TextView
                android:id="@+id/accepted_payment_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Waiting for Payment"
                android:textColor="@color/orange"
                android:textStyle="bold"
                android:gravity="center"
                android:textSize="@dimen/_11sdp"
                android:layout_marginBottom="@dimen/_6sdp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Pickup button (visible when status = accepted) -->
                <Button
                    android:id="@+id/accepted_pickup_btn"
                    style="@style/btn_style"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/_4sdp"
                    android:text="Picked Up"
                    android:visibility="gone" />

                <!-- Complete button (visible when status = picked_up, enabled only when paymentDone) -->
                <Button
                    android:id="@+id/accepted_complete_btn"
                    style="@style/btn_style"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/_4sdp"
                    android:text="Complete Ride"
                    android:backgroundTint="@color/green"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>


    </LinearLayout>

</com.google.android.material.card.MaterialCardView>


