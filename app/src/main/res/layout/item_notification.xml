<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/_8sdp"
    app:cardCornerRadius="@dimen/_10sdp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/lightGray">

    <!-- Left purple accent bar + content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Accent bar (unread = purple, read = transparent) -->
        <View
            android:id="@+id/accentBar"
            android:layout_width="@dimen/_4sdp"
            android:layout_height="match_parent"
            android:background="@color/darkPurple" />

        <!-- Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="@dimen/_12sdp"
            android:paddingEnd="@dimen/_12sdp"
            android:paddingTop="@dimen/_12sdp"
            android:paddingBottom="@dimen/_12sdp">

            <!-- Title row with unread dot -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/notificationTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Notification Title"
                    android:textColor="@color/darkPurple"
                    android:textSize="@dimen/_13sdp"
                    android:textStyle="bold" />

                <!-- Unread dot -->
                <View
                    android:id="@+id/unreadDot"
                    android:layout_width="@dimen/_8sdp"
                    android:layout_height="@dimen/_8sdp"
                    android:background="@drawable/bg_badge_circle"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Message -->
            <TextView
                android:id="@+id/notificationMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Notification message goes here"
                android:textColor="@color/darkGray"
                android:textSize="@dimen/_11sdp"
                android:layout_marginTop="@dimen/_4sdp"
                android:lineSpacingExtra="@dimen/_2sdp" />

            <!-- Timestamp -->
            <TextView
                android:id="@+id/notificationTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Just now"
                android:textColor="@color/lightPurple"
                android:textSize="@dimen/_10sdp"
                android:layout_marginTop="@dimen/_6sdp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
