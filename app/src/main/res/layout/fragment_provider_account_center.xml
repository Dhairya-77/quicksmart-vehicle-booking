<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/_15sdp">

        <!-- ── Avatar + Provider Info ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="@dimen/_15sdp">

            <!-- Circular avatar -->
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/img_avatar"
                android:layout_width="@dimen/_90sdp"
                android:layout_height="@dimen/_90sdp"
                android:src="@drawable/ic_person"
                android:padding="5dp"
                android:background="@drawable/bg_circle_border" />

            <!-- Provider Name -->
            <TextView
                android:id="@+id/provider_name"
                style="@style/subtitle_style"
                android:layout_marginTop="@dimen/_10sdp"
                android:text="Provider Name"
                android:textColor="@color/darkPurple"
                android:textStyle="bold"
                android:textSize="@dimen/_14sdp" />

        </LinearLayout>

        <!-- ── Earnings Card ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_earnings"
            style="@style/textbox_card_style"
            android:layout_marginBottom="@dimen/_15sdp"
            app:cardBackgroundColor="@color/lightGray"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/_15sdp">

                <!-- Header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/_8sdp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/_22sdp"
                        android:layout_height="@dimen/_22sdp"
                        android:layout_marginEnd="@dimen/_10sdp"
                        android:contentDescription="Earnings"
                        android:src="@drawable/ic_wallet"
                        app:tint="@color/darkPurple" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Monthly Earnings"
                        android:textColor="@color/darkPurple"
                        android:textSize="@dimen/_14sdp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/total_earnings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹ 0.0"
                        android:textColor="@color/darkPurple"
                        android:textSize="@dimen/_15sdp"
                        android:textStyle="bold"
                        android:layout_marginStart="@dimen/_4sdp"/>

                </LinearLayout>

                <!-- Transfer notice -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="@dimen/_2sdp"
                    android:text="💡 Money will be transferred to your account on the 1st week of every month."
                    android:textColor="@color/darkPurple"
                    android:textSize="@dimen/_11sdp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ── Menu Items ── -->

        <!-- Edit Profile -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_profile_edit"
            style="@style/textbox_card_style"
            android:layout_marginBottom="@dimen/_10sdp"
            app:cardBackgroundColor="@color/lightGray"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/_50sdp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/_12sdp"
                android:paddingEnd="@dimen/_12sdp">

                <ImageView
                    android:layout_width="@dimen/_22sdp"
                    android:layout_height="@dimen/_22sdp"
                    android:src="@drawable/ic_person"
                    app:tint="@color/darkPurple"
                    android:contentDescription="Edit Profile"
                    android:layout_marginEnd="@dimen/_12sdp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Edit Profile"
                    android:textColor="@color/darkPurple"
                    android:textSize="@dimen/_14sdp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:src="@drawable/ic_right_arrow"
                    android:contentDescription="Go" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Daily Earnings -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_daily_earnings"
            style="@style/textbox_card_style"
            android:layout_marginBottom="@dimen/_10sdp"
            app:cardBackgroundColor="@color/lightGray"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/_50sdp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/_12sdp"
                android:paddingEnd="@dimen/_12sdp">

                <ImageView
                    android:layout_width="@dimen/_22sdp"
                    android:layout_height="@dimen/_22sdp"
                    android:src="@drawable/ic_transaction"
                    app:tint="@color/darkPurple"
                    android:contentDescription="Daily Earnings"
                    android:layout_marginEnd="@dimen/_12sdp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Daily Earnings"
                    android:textColor="@color/darkPurple"
                    android:textSize="@dimen/_14sdp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:src="@drawable/ic_right_arrow"
                    android:contentDescription="Go" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Booking History -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_booking_history"
            style="@style/textbox_card_style"
            android:layout_marginBottom="@dimen/_10sdp"
            app:cardBackgroundColor="@color/lightGray"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/_50sdp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/_12sdp"
                android:paddingEnd="@dimen/_12sdp">

                <ImageView
                    android:layout_width="@dimen/_22sdp"
                    android:layout_height="@dimen/_22sdp"
                    android:src="@drawable/ic_history"
                    app:tint="@color/darkPurple"
                    android:contentDescription="Booking History"
                    android:layout_marginEnd="@dimen/_12sdp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Booking History"
                    android:textColor="@color/darkPurple"
                    android:textSize="@dimen/_14sdp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:src="@drawable/ic_right_arrow"
                    android:contentDescription="Go" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Terms & Conditions -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_term_and_con"
            style="@style/textbox_card_style"
            android:layout_marginBottom="@dimen/_20sdp"
            app:cardBackgroundColor="@color/lightGray"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/_50sdp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/_12sdp"
                android:paddingEnd="@dimen/_12sdp">

                <ImageView
                    android:layout_width="@dimen/_22sdp"
                    android:layout_height="@dimen/_22sdp"
                    android:src="@drawable/ic_policy"
                    app:tint="@color/darkPurple"
                    android:contentDescription="Terms and Conditions"
                    android:layout_marginEnd="@dimen/_12sdp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Terms &amp; Conditions"
                    android:textColor="@color/darkPurple"
                    android:textSize="@dimen/_14sdp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:src="@drawable/ic_right_arrow"
                    android:contentDescription="Go" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ── Logout Card (red) ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_logout"
            style="@style/textbox_card_style"
            android:layout_marginBottom="@dimen/_20sdp"
            app:cardBackgroundColor="@color/lightGray"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/_50sdp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/_12sdp"
                android:paddingEnd="@dimen/_12sdp">

                <ImageView
                    android:layout_width="@dimen/_22sdp"
                    android:layout_height="@dimen/_22sdp"
                    android:src="@drawable/ic_logout"
                    android:layout_marginEnd="@dimen/_12sdp"
                    android:contentDescription="Logout" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Logout"
                    android:textColor="@color/red"
                    android:textSize="@dimen/_14sdp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:src="@drawable/ic_right_arrow"
                    app:tint="@color/red"
                    android:contentDescription="Go" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
